<!--pages/chat/chat.wxml-->
<view class="chat-page">
  <!-- 顶部导航栏 -->
  <view class="chat-header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-center">
      <text class="teacher-icon">{{teacherInfo.icon}}</text>
      <view class="teacher-info">
        <text class="teacher-name">{{teacherName}}</text>
        <text class="teacher-status">在线</text>
      </view>
    </view>
    <view class="header-right">
      <text class="menu-icon">⋮</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    scroll-y 
    class="message-list" 
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation="{{true}}"
  >
    <!-- 欢迎消息 -->
    <view class="message-item ai-message">
      <view class="message-avatar">
        <text class="avatar-icon">{{teacherInfo.icon}}</text>
      </view>
      <view class="message-content">
        <view class="message-bubble ai-bubble">
          <text class="message-text">你好！我是你的<text class="highlight">{{teacherName}}</text> 👋\n\n我会用<text class="highlight">引导式教学</text>的方式帮助你学习。我不会直接给你答案，而是通过提问引导你自己思考和发现答案。\n\n有什么问题想问我吗？</text>
        </view>
        <text class="message-time">{{currentTime}}</text>
      </view>
    </view>

    <!-- 对话消息 -->
    <block wx:for="{{messages}}" wx:key="id">
      <!-- AI消息 -->
      <view wx:if="{{item.role === 'assistant'}}" class="message-item ai-message" id="msg-{{item.id}}">
        <view class="message-avatar">
          <text class="avatar-icon">{{teacherInfo.icon}}</text>
        </view>
        <view class="message-content">
          <view class="message-bubble ai-bubble">
            <rich-text class="message-text" nodes="{{item.content}}"></rich-text>
          </view>
          <text class="message-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 用户消息 -->
      <view wx:else class="message-item user-message" id="msg-{{item.id}}">
        <view class="message-content">
          <view class="message-bubble user-bubble">
            <text class="message-text">{{item.content}}</text>
          </view>
          <text class="message-time">{{item.time}}</text>
        </view>
        <view class="message-avatar user-avatar">
          <text class="avatar-icon">👨‍🎓</text>
        </view>
      </view>
    </block>

    <!-- 打字指示器 -->
    <view wx:if="{{isTyping}}" class="message-item ai-message">
      <view class="message-avatar">
        <text class="avatar-icon">{{teacherInfo.icon}}</text>
      </view>
      <view class="message-content">
        <view class="message-bubble ai-bubble typing-indicator">
          <view class="typing-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 占位元素，用于滚动到底部 -->
    <view id="bottom" style="height: 1px;"></view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-area">
    <view class="input-container">
      <textarea 
        class="message-input" 
        placeholder="输入你的问题..."
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendMessage"
        auto-height
        maxlength="500"
        show-confirm-bar="{{false}}"
      ></textarea>
      <view class="send-button {{inputText ? 'active' : ''}}" bindtap="sendMessage">
        <text class="send-icon">➤</text>
      </view>
    </view>
  </view>
</view>
