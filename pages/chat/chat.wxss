/* pages/chat/chat.wxss */
.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #f0f4ff 0%, #f8f9ff 100%);
}

/* 顶部导航栏 */
.chat-header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.2);
}

.header-left, .header-right {
  width: 80rpx;
}

.back-icon, .menu-icon {
  font-size: 48rpx;
  color: #ffffff;
}

.header-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.teacher-icon {
  font-size: 64rpx;
}

.teacher-info {
  display: flex;
  flex-direction: column;
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.teacher-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 32rpx 48rpx 32rpx 32rpx;
  overflow-y: scroll;
}

.message-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  animation: fadeInUp 0.3s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* AI消息 */
.ai-message {
  justify-content: flex-start;
}

.ai-message .message-content {
  max-width: 70%;
}

/* 用户消息 */
.user-message {
  justify-content: flex-end;
}

.user-message .message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

/* 头像 */
.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.ai-message .message-avatar {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.user-avatar {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
}

.avatar-icon {
  font-size: 40rpx;
}

/* 消息气泡 */
.message-bubble {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.ai-bubble {
  background: #ffffff;
  border-top-left-radius: 4rpx;
}

.user-bubble {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-top-right-radius: 4rpx;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1e293b;
  word-wrap: break-word;
}

.user-bubble .message-text {
  color: #ffffff;
}

.highlight {
  font-weight: 600;
  color: #6366f1;
}

.user-bubble .highlight {
  color: #fbbf24;
}

/* 消息操作栏 */
.message-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  margin-left: 8rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.action-btn:active {
  background: #f1f5f9;
  transform: scale(0.95);
}

.action-icon {
  font-size: 24rpx;
  color: #94a3b8;
}

.action-text {
  font-size: 20rpx;
  color: #94a3b8;
}

.favorite-btn.active {
  background: #fffbeb;
  border-color: #fde68a;
}

.favorite-btn.active .action-icon {
  color: #f59e0b;
}

.favorite-btn.active .action-text {
  color: #f59e0b;
}

.message-time {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  margin-left: 12rpx;
}

.user-message .message-time {
  margin-left: 0;
  margin-right: 12rpx;
}

/* 打字指示器 */
.typing-indicator {
  padding: 20rpx 32rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #94a3b8;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-8rpx);
  }
}

/* 输入区域 */
.input-area {
  background: #ffffff;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.input-container {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  background: #f3f4f6;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}

.message-input {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
  max-height: 200rpx;
  background: transparent;
}

.send-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.send-button.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.4);
  transform: scale(1.05);
}

.send-icon {
  font-size: 32rpx;
  color: #ffffff;
}
