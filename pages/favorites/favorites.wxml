<view class="favorites-page">
  <view class="header-desc" wx:if="{{favorites.length > 0}}">
    <text>共 {{favorites.length}} 条收藏</text>
  </view>

  <view class="empty-state" wx:if="{{favorites.length === 0}}">
    <text class="empty-icon">⭐</text>
    <text class="empty-text">还没有收藏过精彩内容呢</text>
    <text class="empty-tip">在聊天时点击星星即可收藏</text>
  </view>

  <scroll-view scroll-y class="favorites-list" wx:else>
    <view class="fav-item" wx:for="{{favorites}}" wx:key="id">
      <view class="fav-header">
        <view class="teacher-tag">
          <text class="teacher-icon">{{item.icon}}</text>
          <text class="teacher-name">{{item.teacher}}</text>
        </view>
        <view class="star-btn" bindtap="removeFavorite" data-id="{{item.id}}">
          <text class="star-icon">⭐</text>
        </view>
      </view>
      
      <view class="fav-content">
        <rich-text nodes="{{item.displayContent}}"></rich-text>
      </view>
      
      <view class="fav-footer">
        <text class="fav-date">{{item.dateStr}}</text>
      </view>
    </view>
  </scroll-view>
</view>
