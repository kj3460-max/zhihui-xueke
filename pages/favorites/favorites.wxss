.favorites-page {
  min-height: 100vh;
  background: #f8fafc;
  padding: 32rpx;
}

.header-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
  padding-left: 8rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.2;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #94a3b8;
}

.fav-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.fav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
  padding-bottom: 20rpx;
}

.teacher-tag {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.teacher-icon {
  font-size: 36rpx;
}

.teacher-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #6366f1;
}

.star-icon {
  font-size: 36rpx;
  color: #f59e0b;
  padding: 10rpx;
}

.fav-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #334155;
}

.fav-footer {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.fav-date {
  font-size: 20rpx;
  color: #94a3b8;
}
