.history-page {
  min-height: 100vh;
  background: #f8fafc;
}

.history-list {
  padding: 20rpx 0;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #ffffff;
  margin-bottom: 2rpx;
  transition: background 0.2s;
}

.history-item:active {
  background: #f1f5f9;
}

.teacher-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-icon {
  font-size: 50rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.last-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.info-bottom {
  display: flex;
}

.last-msg {
  font-size: 26rpx;
  color: #64748b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.arrow {
  color: #cbd5e1;
  font-size: 40rpx;
  margin-left: 16rpx;
  font-weight: 300;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.2;
}

.empty-text {
  font-size: 32rpx;
  color: #64748b;
  font-weight: 600;
}

.empty-tip {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}
