/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #e0e7ff 0%, #f3e8ff 50%, #ede9fe 100%);
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 32rpx 32rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-container {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  gap: 16rpx;
}

.logo-image {
  width: 200rpx;
  height: 40rpx;
}

.logo-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-info {
  position: relative;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

/* 内容区域 */
.content {
  height: calc(100vh - 200rpx);
  padding: 32rpx 20rpx;
}

/* 分类区域 */
.section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 0;
  width: 72rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #c4b5fd 0%, #7c3aed 100%);
  border-radius: 6rpx;
}

.section-count {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 老师卡片网格 */
.teacher-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin: 0 auto;
  max-width: 680rpx;
}

/* 老师卡片 */
.teacher-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(32rpx);
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.teacher-card:active {
  transform: translateY(-4rpx) scale(1.02);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.teacher-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.teacher-card:active .teacher-icon {
  transform: scale(1.1);
}

.teacher-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.teacher-desc {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
}
/* 勋章弹窗样式 */
.medal-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.medal-mask {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(10rpx);
}

.medal-card-container {
  position: relative;
  z-index: 1001;
  width: 580rpx;
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes popIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.medal-card-body {
  background: #ffffff;
  border-radius: 48rpx;
  overflow: hidden;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.medal-header {
  margin-bottom: 40rpx;
}

.wow-text {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.medal-main {
  position: relative;
  margin: 60rpx 0;
  width: 240rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.medal-glow {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(245, 158, 11, 0.3) 0%, transparent 70%);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 0.8; }
  100% { transform: scale(1); opacity: 0.5; }
}

.medal-big-circle {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(245, 158, 11, 0.4);
  border: 10rpx solid #fff;
  z-index: 2;
}

.medal-big-icon {
  font-size: 100rpx;
}

.medal-footer {
  text-align: center;
  margin-bottom: 48rpx;
}

.medal-big-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.medal-big-desc {
  font-size: 26rpx;
  color: #64748b;
}

.medal-btn {
  width: 100%;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.3);
}

.medal-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 悬浮扫码按钮 */
.scan-fab {
  position: fixed;
  bottom: 60rpx;
  right: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  z-index: 99;
}

.fab-circle {
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.4);
  border: 4rpx solid #ffffff;
  animation: breath 3s infinite ease-in-out;
}

@keyframes breath {
  0% { transform: scale(1); box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.4); }
  50% { transform: scale(1.08); box-shadow: 0 16rpx 48rpx rgba(99, 102, 241, 0.6); }
  100% { transform: scale(1); box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.4); }
}

.fab-icon {
  font-size: 56rpx;
}

.fab-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #6366f1;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(10rpx);
}
