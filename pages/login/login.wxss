.login-page {
  min-height: 100vh;
  background: #f0f4ff;
  position: relative;
  overflow: hidden;
  padding: 0 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 背景修饰 */
.bg-decoration .circle-1 {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(139, 92, 246, 0.1));
}

.bg-decoration .circle-2 {
  position: absolute;
  bottom: -50rpx;
  left: -50rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(99, 102, 241, 0.05));
}

.welcome-container {
  position: relative;
  z-index: 10;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.logo-box {
  width: 120rpx;
  height: 120rpx;
  background: #ffffff;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 10rpx 40rpx rgba(99, 102, 241, 0.15);
  margin-bottom: 32rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1e293b;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.welcome-subtitle {
  font-size: 26rpx;
  color: #64748b;
  letter-spacing: 1rpx;
}

.form-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  padding: 60rpx 40rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.input-group {
  margin-bottom: 48rpx;
}

.label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 24rpx;
}

.nickname-input {
  width: 100%;
  height: 100rpx;
  background: #f8fafc;
  border: 4rpx solid #f1f5f9;
  border-radius: 28rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  color: #1e293b;
  transition: all 0.3s;
}

.nickname-input:focus {
  border-color: #6366f1;
  background: #ffffff;
}

.grade-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grade-item {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #64748b;
  transition: all 0.2s;
}

.grade-item.active {
  background: #6366f1;
  color: #ffffff;
  font-weight: 600;
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.start-btn {
  width: 100%;
  height: 100rpx;
  background: #cbd5e1;
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
  transition: all 0.3s;
  border: none;
}

.start-btn.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  box-shadow: 0 10rpx 30rpx rgba(99, 102, 241, 0.4);
}

.btn-arrow {
  font-size: 40rpx;
}

.footer-tip {
  margin-top: 60rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  animation: fadeIn 1s ease-out 0.8s both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 0.8; }
}
