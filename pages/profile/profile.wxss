/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0f4ff 0%, #f8f9ff 100%);
  padding-bottom: 120rpx;
}

/* 顶部个人信息 */
.profile-header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 60rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.avatar-container {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  border: 6rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-icon {
  font-size: 80rpx;
}

.edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 24rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.username {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 数字学生证 */
.id-card-section {
  padding: 0 32rpx;
  margin-top: -30rpx;
  position: relative;
  z-index: 10;
}

.id-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.card-left {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 4rpx;
}

.card-subtitle {
  font-size: 20rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

.id-tag {
  background: #f1f5f9;
  color: #6366f1;
  font-size: 28rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  display: inline-block;
  width: fit-content;
  letter-spacing: 2rpx;
}

.print-tip {
  font-size: 18rpx;
  color: #cbd5e1;
  margin-top: 16rpx;
}

.qr-placeholder {
  width: 140rpx;
  height: 140rpx;
  background: #f8fafc;
  border: 4rpx solid #e2e8f0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.qr-icon {
  font-size: 80rpx;
  color: #334155;
}

.qr-scan-line {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 2rpx;
  background: #6366f1;
  box-shadow: 0 0 10rpx #6366f1;
  animation: scanning 2.5s infinite linear;
}

@keyframes scanning {
  0% { top: 0%; }
  100% { top: 100%; }
}

/* 学习统计 */
.stats-container {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(32rpx);
  margin: 32rpx 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, #e2e8f0, transparent);
}

/* 勋章墙 */
.medal-section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(32rpx);
  margin: 0 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-more {
  font-size: 24rpx;
  color: #6366f1;
}

.medal-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.medal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.medal-item:active {
  transform: scale(0.9);
}

.medal-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff 0%, #f0f4ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(99, 102, 241, 0.1);
  position: relative;
  border: 4rpx solid #fff;
}

.medal-icon {
  font-size: 50rpx;
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(2rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  opacity: 0.8;
}

.medal-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}

.medal-condition {
  font-size: 20rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.2;
}

.medal-item.locked .medal-icon {
  filter: grayscale(1);
  opacity: 0.4;
}

.medal-item.locked .medal-name {
  color: #94a3b8;
}

/* 功能菜单 */
.menu-section {
  margin: 0 32rpx 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(32rpx);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f1f5f9;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.icon {
  font-size: 36rpx;
}

.menu-title {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-arrow {
  font-size: 48rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* 版本信息 */
.version-info {
  display: flex;
  justify-content: center;
  padding: 32rpx;
}

.version-text {
  font-size: 24rpx;
  color: #94a3b8;
}
